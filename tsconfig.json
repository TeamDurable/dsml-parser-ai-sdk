{
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"esModuleInterop": true,
		"exactOptionalPropertyTypes": true,
		"ignoreDeprecations": "6.0",
		"lib": ["ES2022", "DOM"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2022",
		"types": ["vitest/globals"]
	},
	"include": ["src", "tests"]
}
